// Sitios Web Express — esquema de datos
//
// Decisión clave: la configuración completa de un sitio vive en `Site.config`
// (JSONB) validada con Zod (src/lib/site-config.ts). Es la única fuente de
// verdad para el preview y para el exportador. No hay tablas relacionales
// por sección (el prompt original sugería SiteSection/SiteWidget, pero la
// sección 5 del brief pide explícitamente JSON versionable como fuente de
// verdad — SiteVersion guarda el historial).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BUSINESS_OWNER
}

enum SiteStatus {
  DRAFT
  COMPLETED
  PAID
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(BUSINESS_OWNER)
  sites        Site[]
  createdAt    DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  // Paleta, tipografías (Google Fonts) y defaults de estilo del template.
  config      Json
  // Precio base en MXN (unidades enteras).
  basePrice   Int
  previewUrl  String?
  active      Boolean  @default(true)
  sites       Site[]
  createdAt   DateTime @default(now())
}

model Widget {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  // Tipo de sección que agrega al sitio ("gallery", "faq"...) o "feature"
  // para widgets sin sección propia (ej. multi-idioma).
  sectionType String?
  icon        String   @default("puzzle")
  price       Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Site {
  id         String        @id @default(cuid())
  name       String
  status     SiteStatus    @default(DRAFT)
  // Los sitios no requieren cuenta: se accede con la editKey (URL secreta).
  // userId solo se usa si algún día se vinculan a una cuenta.
  user       User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String?
  editKey    String        @unique
  template   Template      @relation(fields: [templateId], references: [id])
  templateId String
  // Fuente de verdad: SiteConfig (ver src/lib/site-config.ts)
  config     Json
  versions   SiteVersion[]
  invoice    Invoice?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model SiteVersion {
  id        String   @id @default(cuid())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String
  config    Json
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}

// Estado de una conversación de onboarding por WhatsApp (bot de wapisimo.dev)
model WhatsappConversation {
  id        String   @id @default(cuid())
  // Número normalizado E.164 (+521...)
  phone     String   @unique
  state     String   @default("start")
  // Respuestas acumuladas del formulario conversacional
  data      Json     @default("{}")
  siteId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id     String        @id @default(cuid())
  site   Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId String        @unique
  // [{ label, qty, unitPrice, subtotal }] — snapshot calculado en cada guardado
  lineItems Json
  total     Int
  status    InvoiceStatus @default(DRAFT)
  updatedAt DateTime      @updatedAt
}
